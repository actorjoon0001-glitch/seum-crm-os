# ── Supabase 연결 정보 ────────────────────────────────────────────
# 이미 운영 중인 "방문예약폼"의 Supabase 프로젝트 값을 그대로 넣으면
# 고객관리os가 그 데이터에 바로 연동됩니다.
# Supabase 대시보드 > Project Settings > API 에서 확인하세요.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 관리자 대시보드의 서버 작업(상태 변경 등)에 사용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
