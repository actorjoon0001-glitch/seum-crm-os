# ── Supabase 연결 정보 ────────────────────────────────────────────
# 이미 운영 중인 "방문예약폼"의 Supabase 프로젝트 값을 그대로 넣으면
# 고객관리os가 그 데이터에 바로 연동됩니다.
# Supabase 대시보드 > Project Settings > API (Data API) 에서 확인하세요.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# 공개(클라이언트)용 키. 새 형식 sb_publishable_... 또는 기존 anon JWT 모두 가능.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# 서버 전용 비밀 키. 대시보드가 RLS를 우회해 계약 데이터를 조회할 때 사용.
# 새 형식 sb_secret_... 또는 기존 service_role JWT. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── 관리자 로그인 ─────────────────────────────────────────────────
# 고객관리OS 접속용 단일 관리자 비밀번호. 반드시 설정하세요(미설정 시 전체 잠김).
ADMIN_PASSWORD=원하는비밀번호

# ── (선택) 테이블명이 다를 때 매핑 ────────────────────────────────
# 세움 기존 테이블명을 사용합니다. 다르면 아래로 덮어쓰세요.
# SUPABASE_CONTRACTS_TABLE=contracts
# SUPABASE_DRAWINGS_TABLE=contract_drawings
# SUPABASE_CUSTOMERS_TABLE=customers
